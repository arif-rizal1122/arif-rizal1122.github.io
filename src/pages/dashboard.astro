---
import Layout from '../layouts/Layout.astro';
import TasksWidget from '../components/TasksWidget';
---

<Layout title="Dashboard Pribadi - Arif Rizal">
  <!--
    PERBAIKAN RESPONSIF:
    - pt-20 md:pt-28 lg:pt-32  → di mobile navbar lebih compact, jadi pt lebih kecil
    - pb-8 md:pb-24            → padding bawah normal, tidak berlebihan di mobile
    - TasksWidget sudah punya pb-28 sendiri di mobile, jadi tidak perlu pb besar di sini
  -->
  <main class="pt-20 md:pt-28 lg:pt-32 pb-8 md:pb-24">
    <div class="container mx-auto px-4 md:px-6">

      <!-- Page Header -->
      <div class="text-center mb-10 md:mb-16">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 md:mb-4">Personal Dashboard</h1>
        <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto text-sm md:text-base">
          Ringkasan profil dan manajemen tugas harian Anda.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">

        <!-- Profile Card -->
        <div class="lg:col-span-1">
          <div class="bg-white dark:bg-gray-800 p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-700">
            <!-- Di mobile: layout horizontal agar lebih compact -->
            <div class="flex flex-row lg:flex-col items-center gap-5 lg:gap-0 lg:text-center">
              <img
                src="/img/gem.png"
                alt="Arif Rizal"
                class="w-20 h-20 md:w-28 md:h-28 lg:w-32 lg:h-32 lg:mx-auto rounded-full shrink-0
                       border-4 border-indigo-50 dark:border-indigo-900 object-cover
                       lg:mb-6"
              />
              <div class="flex-1 lg:w-full">
                <h3 class="text-lg md:text-xl lg:text-2xl font-bold dark:text-white">Arif Rizal</h3>
                <p class="text-indigo-600 font-medium uppercase tracking-widest text-[10px] md:text-xs lg:mb-6 mb-2">
                  Backend Developer
                </p>
                <!-- Info items — hidden di mobile kecil, tampil di md ke atas -->
                <div class="hidden md:space-y-3 md:block text-left">
                  <div class="flex items-center gap-3 text-xs md:text-sm text-gray-600 dark:text-gray-400">
                    <i class="fas fa-code w-4 text-indigo-500 shrink-0"></i>
                    <span>Laravel, Go, Java, MySQL</span>
                  </div>
                  <div class="flex items-center gap-3 text-xs md:text-sm text-gray-600 dark:text-gray-400">
                    <i class="fas fa-map-marker-alt w-4 text-indigo-500 shrink-0"></i>
                    <span>Jakarta Selatan, ID</span>
                  </div>
                  <div class="flex items-center gap-3 text-xs md:text-sm text-gray-600 dark:text-gray-400">
                    <i class="fas fa-calendar-alt w-4 text-indigo-500 shrink-0"></i>
                    <span>Aktif Sejak 2024</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Info items mobile (compact chips) -->
            <div class="flex flex-wrap gap-2 mt-4 md:hidden">
              <span class="inline-flex items-center gap-1.5 text-[10px] px-2.5 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 font-medium">
                <i class="fas fa-code text-[9px]"></i> Laravel · Go · Java
              </span>
              <span class="inline-flex items-center gap-1.5 text-[10px] px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 font-medium">
                <i class="fas fa-map-marker-alt text-[9px]"></i> Jakarta Selatan
              </span>
              <span class="inline-flex items-center gap-1.5 text-[10px] px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 font-medium">
                <i class="fas fa-calendar-alt text-[9px]"></i> Aktif 2024
              </span>
            </div>

            <!-- Social Links -->
            <div class="mt-5 md:mt-8 pt-5 md:pt-8 border-t border-gray-100 dark:border-gray-700 flex justify-center gap-4">
              <a
                href="https://github.com/arif-rizal1122"
                aria-label="GitHub Profil"
                target="_blank"
                class="w-9 h-9 md:w-10 md:h-10 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-gray-900 hover:text-white transition-all text-sm"
              >
                <i class="fab fa-github"></i>
              </a>
              <a
                href="javascript:void(0)"
                aria-label="LinkedIn Profil"
                class="w-9 h-9 md:w-10 md:h-10 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-blue-600 hover:text-white transition-all text-sm"
              >
                <i class="fab fa-linkedin-in"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Tasks + Quick Links Section -->
        <div class="lg:col-span-2 flex flex-col gap-6 md:gap-8">
          <TasksWidget client:load />

          <!-- Quick Links -->
          <div class="grid grid-cols-2 gap-4 md:gap-6">
            <a
              href="/notes"
              class="bg-yellow-50 dark:bg-yellow-900/20 p-4 md:p-6 rounded-2xl border border-yellow-100 dark:border-yellow-800 hover:shadow-md transition-shadow group"
            >
              <div class="flex justify-between items-start mb-3 md:mb-4">
                <i class="fas fa-sticky-note text-yellow-500 text-lg md:text-xl"></i>
                <i class="fas fa-arrow-right text-yellow-300 group-hover:translate-x-1 transition-transform text-sm"></i>
              </div>
              <h4 class="font-bold mb-1 text-sm md:text-base">Buka Catatan</h4>
              <p class="text-xs text-gray-500 hidden sm:block">Kelola ide dan snippet kode Anda.</p>
            </a>
            <a
              href="/projects"
              class="bg-indigo-50 dark:bg-indigo-900/20 p-4 md:p-6 rounded-2xl border border-indigo-100 dark:border-indigo-800 hover:shadow-md transition-shadow group"
            >
              <div class="flex justify-between items-start mb-3 md:mb-4">
                <i class="fas fa-project-diagram text-indigo-500 text-lg md:text-xl"></i>
                <i class="fas fa-arrow-right text-indigo-300 group-hover:translate-x-1 transition-transform text-sm"></i>
              </div>
              <h4 class="font-bold mb-1 text-sm md:text-base">Kelola Proyek</h4>
              <p class="text-xs text-gray-500 hidden sm:block">Lihat dan update portofolio Anda.</p>
            </a>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>